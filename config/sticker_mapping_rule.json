        "rules": [
          {
            "pattern": "\\((유광코팅|무코팅|유광|무광)\\)",
            "extract_to": "coating",
            "remove_from_paper_name": true,
            "prefix_map": {
              "무코팅": "비코팅",
              "유광": "유광코팅",
              "무광": "무광코팅"
